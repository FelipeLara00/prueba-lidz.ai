generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "sqlite"
}

model Client {
  id       String   @id @default(uuid())
  name     String
  rut      String   @unique
  salary   Int
  savings  Int

  messages Message[]
  debts    Debt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id      String   @id @default(uuid())
  text    String
  role    Role
  sentAt  DateTime

  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  createdAt DateTime @default(now())
}

model Debt {
  id          String   @id @default(uuid())
  institution String
  amount      Int
  dueDate     DateTime

  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String

  createdAt DateTime @default(now())
}

enum Role {
  client
  agent
}
